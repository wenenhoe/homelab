// Managed by Ansible

options {
    directory "/var/cache/bind";

    // Only listen on IPv4
    listen-on { any; };
    listen-on-v6 { none; };

    // Do not allow recursion — authoritative only
    recursion no;
    allow-query { any; };

    dnssec-validation auto;
};

include "/etc/bind/named.conf.local";
