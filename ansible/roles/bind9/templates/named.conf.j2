// Managed by Ansible

options {
    directory "/var/cache/bind";

    // Only listen on localhost — this is an internal resolver
    listen-on { 127.0.0.1; };
    listen-on-v6 { none; };

    // Do not allow recursion — authoritative only
    recursion no;
    allow-query { any; };

    dnssec-validation auto;
};

include "/etc/bind/named.conf.local";
