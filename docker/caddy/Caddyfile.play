{
    # Define issuers globally with public resolvers
    cert_issuer acme {
        dns digitalocean {env.DO_API_TOKEN}
        resolvers 1.1.1.1 8.8.8.8
    }
}

*.play.example.com {
    @bluemap host bluemap.play.example.com
    handle @bluemap {
        reverse_proxy bluemap:8100
    }

    @dockge host dockge.play.example.com
    handle @dockge {
        reverse_proxy dockge:5001
    }
}
